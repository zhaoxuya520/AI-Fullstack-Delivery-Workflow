        { "name": "ESLint", "check_cmd": "eslint", "install_cmd": "pnpm add -g eslint", "category": "lint", "required": true },
        { "name": "Prettier", "check_cmd": "prettier", "install_cmd": "pnpm add -g prettier", "category": "format", "required": true },
